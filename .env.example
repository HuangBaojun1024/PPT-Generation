# 复制为 .env 并填入真实值（.env 已被 .gitignore，不入库）
# 公网代理商的 baseURL 写在 config/models.json；内部网关地址不入库，从这里传入。

# saturday 网关：文本模型 gpt-5.5 / glm-5.1，生图 gpt-image-2
# 网关地址（OpenAI 兼容协议，形如 https://<your-gateway>/v1），向仓库所有者索取
SATURDAY_BASE_URL=
SATURDAY_API_KEY=

# haoai 网关：Anthropic 系列（claude-fable-5 / claude-opus-4-7），仅 full preset 需要
HAOAI_API_KEY=

# apimart：生图兜底（gpt-image-2 不可用时切换）
APIMART_API_KEY=
